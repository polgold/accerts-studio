# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App (optional, for public share URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin: email del admin (para restricciones y notificaciones)
ADMIN_EMAIL=admin@example.com
# UUID del usuario admin (para enviarle notificaciones al comentar; opcional)
ADMIN_USER_ID=
# Emails con acceso especial (ver proyectos, confidenciales en lectura, comentar). Separados por coma.
SPECIAL_ACCESS_EMAILS=
