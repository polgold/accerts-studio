# Supabase (obligatorio)
# NEXT_PUBLIC_SUPABASE_URL: URL del proyecto en Supabase, ej. https://abcdefgh.supabase.co
# Debe ser el dominio de Supabase, NO el de Vercel ni otro.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URLs (solo para redirects: magic link, callback, etc.)
# Producción: https://accerts-studio.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
